#' @title Atribuir guildas ecológicas a partir de uma matriz de abundância ou riqueza
#'
#' @description Calcula a frequência total de cada espécie, extrai o gênero,
#' associa a guilda ecológica e retorna uma tabela e um gráfico com a proporção das guildas.
#'
#' @param comm Matriz de comunidade com espécies nas colunas e amostras nas linhas.
#'
#' @return Uma lista com dois elementos:
#' \describe{
#'    \item{tabela}{Data frame com espécie, gênero, guilda e abundância total (Sem truncamento no console).}
#'    \item{grafico}{Gráfico ggplot com proporção das guildas na área amostrada (Com barras horizontais para melhor visualização).}
#' }
#' @export
assign_guild_from_matrix <- function(comm) {

  # NOTA: dplyr, ggplot2 e stringr devem estar listados em 'Imports' no arquivo DESCRIPTION.

  # Usamos requireNamespace para carregamento seguro dos pacotes
  requireNamespace("dplyr", quietly = TRUE)
  requireNamespace("ggplot2", quietly = TRUE)
  requireNamespace("stringr", quietly = TRUE)

  # 1. Preparação dos dados e cálculo de abundância
  dados_numericos <- as.data.frame(comm)

  df <- data.frame(
    species = colnames(dados_numericos),
    abundance = colSums(dados_numericos, na.rm = TRUE),
    stringsAsFactors = FALSE
  ) %>%
    # Coerção para tibble para o pipeline do dplyr
    dplyr::as_tibble()


  # 2. Extrair o gênero (Lógica: pegar a primeira palavra)
  # str_split_fixed é robusto para separadores [. _ ou espaço]
  df$genus <- stringr::str_split_fixed(df$species, pattern = "[._ ]", n = 2)[, 1]

  # 3. Base de guildas e associação (Seu dicionário completo)
  guildas_formigas <- data.frame(
    genus = c(
      "Acanthognathus", "Acanthoponera", "Acanthostichus", "Acromyrmex", "Anochetus",
      "Apterostigma", "Atta", "Brachymyrmex", "Camponotus", "Cephalotes", "Crematogaster",
      "Cyphomyrmex", "Ectatomma", "Heteroponera", "Holcoponera", "Hylomyrma", "Hypoponera",
      "Labidus", "Linepithema", "Mycocepurus", "Neivamyrmex", "Neocerapachys", "Neoponera",
      "Octostruma", "Odontomachus", "Oxyepoecus", "Pachycondyla", "Paratrechina", "Pheidole",
      "Procryptocerus", "Pseudomyrmex", "Solenopsis", "Strumigenys", "Wasmannia",
      "Dorymyrmex", "Myrmelachista", "Nylanderia", "Rasopone", "Cylindromyrmex",
      "Mycetophylax", "Mycetomoellerius", "Fulakora", "Megalomyrmex", "Gnamptogenys", "Basiceros"
    ),
    guild = c(
      "Specialist litter or soil predators (cryptic)",
      "Specialist litter or soil predators (cryptic)",
      "Generalist predators (dominant or cryptic in soil or leaf litter)",
      "Fungus-growers (soil or leaf litter nesting)",
      "Generalist predators (dominant or cryptic in soil or leaf litter)",
      "Fungus-growers (soil or leaf litter nesting)",
      "Fungus-growers (soil or leaf litter nesting)",
      "Generalist omnivores (dominant or opportunistic in soil, leaf litter, or arboreal)",
      "Generalist omnivores (dominant or opportunistic in soil, leaf litter, or arboreal)",
      "Anemophilous pollen consumers (arboreal nesting)",
      "Generalist omnivores (dominant or opportunistic in soil, leaf litter, or arboreal)",
      "Fungus-growers (soil or leaf litter nesting)",
      "Generalist predators (dominant or cryptic in soil or leaf litter)",
      "Generalist omnivores (dominant or opportunistic in soil, leaf litter, or arboreal)",
      "Generalist predators (dominant or cryptic in soil or leaf litter)",
      "Generalist predators (dominant or cryptic in soil or leaf litter)",
      "Specialist litter or soil predators (cryptic)",
      "Generalist predators (dominant or cryptic in soil or leaf litter)",
      "Generalist omnivores (dominant or opportunistic in soil, leaf litter, or arboreal)",
      "Fungus-growers (soil or leaf litter nesting)",
      "Specialist litter or soil predators (cryptic)",
      "Specialist litter or soil predators (cryptic)",
      "Specialist litter or soil predators (cryptic)",
      "Specialist litter or soil predators (cryptic)",
      "Generalist predators (dominant or cryptic in soil or leaf litter)",
      "Leaf litter omnivores and scavengers (cryptic or non-cryptic)",
      "Specialist litter or soil predators (cryptic)",
      "Generalist omnivores (dominant or opportunistic in soil, leaf litter, or arboreal)",
      "Leaf litter omnivores and scavengers (cryptic or non-cryptic)",
      "Anemophilous pollen consumers (arboreal nesting)",
      "Leaf litter omnivores and scavengers (cryptic or non-cryptic)",
      "Specialist litter or soil predators (cryptic)",
      "Generalist omnivores (dominant or opportunistic in soil, leaf litter, or arboreal)",
      "Generalist predators (dominant or cryptic in soil or leaf litter)",
      "Leaf litter omnivores and scavengers (cryptic or non-cryptic)",
      "Generalist omnivores (dominant or opportunistic in soil, leaf litter, or arboreal)",
      "Generalist omnivores (dominant or opportunistic in soil, leaf litter, or arboreal)",
      "Generalist predators (dominant or cryptic in soil or leaf litter)",
      "Specialist litter or soil predators (cryptic)",
      "Fungus-growers (soil or leaf litter nesting)",
      "Fungus-growers (soil or leaf litter nesting)",
      "Specialist litter or soil predators (non-cryptic)",
      "Generalist predators (dominant or cryptic in soil or leaf litter)",
      "Specialist litter or soil predators (cryptic)",
      "Generalist predators (dominant or cryptic in soil or leaf litter)"
    ),
    stringsAsFactors = FALSE
  ) %>%
    dplyr::as_tibble() # Coerção para tibble

  # 4. Associar guilda
  df <- dplyr::left_join(df, guildas_formigas, by = "genus")

  # Preencher guildas desconhecidas
  df$guild[is.na(df$guild)] <- "Guilda desconhecida"

  # 5. Resumo e Gráfico
  resumo <- df %>%
    dplyr::group_by(guild) %>%
    dplyr::summarise(total_abundance = sum(abundance), .groups = "drop") %>%
    dplyr::mutate(prop = total_abundance / sum(total_abundance))

  # CRIAÇÃO DO GRÁFICO (SOLUÇÃO FINAL: BARRAS HORIZONTAIS)
  grafico <- ggplot2::ggplot(resumo, ggplot2::aes(x = reorder(guild, prop), y = prop, fill = guild)) +
    ggplot2::geom_col() +
    # Inverte os eixos para usar barras horizontais (ótimo para nomes de categorias longas)
    ggplot2::coord_flip() +
    ggplot2::labs(
      y = "Proporção da Abundância Total",
      x = "Guilda Ecológica",
      title = "Proporção das Guildas Ecológicas na Comunidade"
    ) +
    ggplot2::theme_minimal() +
    ggplot2::theme(
      # Remove a legenda
      legend.position = "none",
      # Aumenta um pouco o texto do eixo Y (guildas) para garantir legibilidade
      axis.text.y = ggplot2::element_text(size = 14)
    )

  # 6. Retorno (CORREÇÃO: Retornar como Data Frame Clássico para evitar truncamento no console)
  return(list(
    tabela = as.data.frame(df),
    grafico = grafico
  ))
}


# ============================================================
# ADDITIONAL CLASSIFICATION: Poneromorph guilds (Silva et al. 2015)
# ============================================================

#' @title Assign poneromorph ant guilds following Silva et al. (2015)
#'
#' @description
#' This function performs an additional classification of poneromorph ants
#' into ecological guilds based on Silva et al. (2015), without modifying
#' the results generated by the previous guild classification.
#'
#' Species-level classification is applied only when genus and specific epithet
#' exactly match the species names provided in the community matrix.
#' When only the genus is available, a generic-level classification is applied.
#' Species name mismatches remain unclassified.
#'
#' @param comm A community matrix with samples in rows and species in columns.
#'
#' @return A data frame with species, genus, abundance and poneromorph guilds.
#'
#' @references
#' Silva, R. R., Silvestre, R., Brandão, C. R. F., Morini, M. S. C., & Delabie, J. H. C. (2015).
#' Grupos tróficos e guildas em formigas poneromorfas. Sociobiology, 62(2), 274–288.
#'
#' @export
assign_poneromorph_guild_silva2015 <- function(comm) {

  requireNamespace("dplyr", quietly = TRUE)
  requireNamespace("stringr", quietly = TRUE)
  requireNamespace("tibble", quietly = TRUE)

  # ------------------------------------------------------------
  # MESSAGE TO THE USER (PACKAGE MESSAGE)
  # ------------------------------------------------------------
  message(
    "Poneromorph guild classification following Silva et al. (2015).\n",
    "Species-level assignment is applied only when species names exactly match\n",
    "the community matrix. Otherwise, classification is performed at the genus\n",
    "level when available. Name mismatches remain unclassified."
  )

  # ------------------------------------------------------------
  # COMMUNITY DATA
  # ------------------------------------------------------------
  df <- tibble::tibble(
    species = colnames(comm),
    abundance = colSums(as.data.frame(comm), na.rm = TRUE)
  ) %>%
    dplyr::mutate(
      genus = stringr::str_split_fixed(species, "[._ ]", 2)[, 1]
    )

  # ------------------------------------------------------------
  # SPECIES-LEVEL GUILDS (STRICT MATCH)
  # ------------------------------------------------------------
  guildas_especie <- tibble::tibble(
    species = c(
      "Heteroponera microps","Heteroponera mayri","Gnamptogenys annulata",
      "Gnamptogenys continua","Gnamptogenys reichenspergeri",
      "Pseudoponera gilberti","Pseudoponera lenkoi","Pseudoponera stigma",
      "Neoponera bucki","Rasopone ferruginea","Dinoponera australis",
      "Dinoponera quadridens","Pachycondyla crassinoda","Pachycondyla harpax",
      "Pachycondyla striata","Pachycondyla impressa","Neoponera villosa",
      "Odontomachus haematodus","Neoponera crenata","Neoponera unidentata",
      "Neoponera insignis","Neoponera luteola","Neoponera fisheri",
      "Paraponera clavata","Odontomachus hastatus","Anochetus mayri"
    ),
    poneromorph_guild = c(
      rep("Small, generalist, low-agility ponerines living in the leaf litter", 10),
      rep("Large, solitary epigeic predatory ponerines", 7),
      rep("Poneromorphs with arboreal activity", 9)
    )
  )

  # ------------------------------------------------------------
  # GENUS-LEVEL GUILDS (WHEN SPECIES IS ABSENT)
  # ------------------------------------------------------------
  guildas_genero <- tibble::tibble(
    genus = c(
      "Heteroponera","Hypoponera","Gnamptogenys","Pseudoponera","Neoponera",
      "Rasopone","Dinoponera","Pachycondyla","Ectatomma","Holcoponera",
      "Anochetus","Odontomachus","Platythyrea","Paraponera","Stigmatomma",
      "Prionopelta","Typhlomyrmex","Acropyga","Probolomyrmex","Simopelta",
      "Leptogenys"
    ),
    poneromorph_guild_genus = c(
      "Small, generalist, low-agility ponerines living in the leaf litter",
      "Small, generalist, low-agility ponerines living in the leaf litter",
      "Generalist predatory ectaheteromorphs",
      "Small, generalist, low-agility ponerines living in the leaf litter",
      "Poneromorphs with arboreal activity",
      "Small, generalist, low-agility ponerines living in the leaf litter",
      "Large, solitary epigeic predatory ponerines",
      "Large, solitary epigeic predatory ponerines",
      "Generalist predatory ectaheteromorphs",
      "Generalist predatory ectaheteromorphs",
      "Poneromorphs with arboreal activity",
      "Poneromorphs with arboreal activity",
      "Poneromorphs with arboreal activity",
      "Poneromorphs with arboreal activity",
      "Specialized cryptic ponerines",
      "Specialized cryptic ponerines",
      "Specialized cryptic ponerines",
      "Specialized cryptic ponerines",
      "Specialized cryptic ponerines",
      "Semi-nomadic ponerines with column foraging",
      "Semi-nomadic ponerines with column foraging"
    )
  )

  # ------------------------------------------------------------
  # APPLY RULES (SPECIES > GENUS > UNCLASSIFIED)
  # ------------------------------------------------------------
  df <- df %>%
    dplyr::left_join(guildas_especie, by = "species") %>%
    dplyr::left_join(guildas_genero, by = "genus") %>%
    dplyr::mutate(
      poneromorph_guild = dplyr::if_else(
        !is.na(poneromorph_guild),
        poneromorph_guild,
        poneromorph_guild_genus
      ),
      poneromorph_guild = dplyr::if_else(
        is.na(poneromorph_guild),
        "Unclassified (name mismatch)",
        poneromorph_guild
      )
    ) %>%
    dplyr::select(-poneromorph_guild_genus)

  return(as.data.frame(df))
}
