library(testthat)
library(AntClassify)
# Dados para o teste
test_data <- data.frame(
"Pheidole megacephala" = 10, "Strumigenys emmae" = 5,
"Paratrechina longicornis" = 8, "Hypoponera leninei" = 3,
"Camponotus fallatus" = 2, "Ectatomma brunneum" = 1,
check.names = FALSE
)
test_that("antclassify returns correct filtered results", {
# 1. Roda a função
res <- antclassify(test_data)
# 2. Verifica Exóticas (Acessando a tabela dentro da lista)
exotic_table <- res$exotic$table
expect_equal(nrow(exotic_table), 3) # Agora deve passar se você filtrar na função!
# 3. Verifica Endêmicas
endemic_table <- res$endemic$table
expect_equal(nrow(endemic_table), 2)
# 4. Verifica Raridade
rarity_table <- res$rarity$table
expect_equal(nrow(rarity_table), 1)
expect_match(rarity_table$species, "Ectatomma brunneum")
})
# 1. Limpa o console
cat("\014")
# 2. Carrega as funções novas que você acabou de salvar
devtools::load_all(".")
# 3. Define os dados de teste novamente para garantir
ant_test_data <- data.frame(
"Pheidole megacephala" = 10, "Strumigenys emmae" = 5,
"Paratrechina longicornis" = 8, "Hypoponera leninei" = 3,
"Camponotus fallatus" = 2, "Ectatomma brunneum" = 1,
check.names = FALSE
)
library(testthat)
test_that("antclassify returns correct filtered results", {
# Impede que o R peça "Enter" e trave o teste
devAskNewPage(ask = FALSE)
# Roda o pipeline
res <- antclassify(ant_test_data)
# Teste 1: Exóticas (Deveria ser 3)
expect_equal(nrow(res$exotic$table), 3)
# Teste 2: Endêmicas (Deveria ser 2)
expect_equal(nrow(res$endemic$table), 2)
# Teste 3: Raridade (Deveria ser 1)
expect_equal(nrow(res$rarity$table), 1)
expect_match(res$rarity$table$species, "Ectatomma brunneum")
print("Se você chegou aqui sem erro, seu pacote está oficializado!")
})
