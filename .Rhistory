# =====================================================
# SCRIPT PARA GERAR FIGURAS DO ARTIGO COM FONTES GRANDES
# =====================================================
library(AntClassify)
library(ggplot2)
library(dplyr)
library(scales)
# -----------------------------------------------------
# 1. Dados da comunidade (simulados do artigo)
# -----------------------------------------------------
species_abundance <- c(
Atta_sexdens = 50,
Camponotus_atriceps = 40,
Crematogaster_sp = 35,
Cyphomyrmex_minutus = 30,
Cyphomyrmex_rimosus = 28,
Ectatomma_edentatum = 25,
Heteroponera_mayri = 22,
Holcoponera_striatula = 20,
Monomorium_floricola = 18,
Monomorium_pharaonis = 17,
Pheidole_megacephala = 16,
Strumigenys_emmae = 15,
Strumigenys_rogeri = 14,
Nylanderia_fulva = 13,
Odontomachus_chelifer = 12,
Oxyepoecus_reticulatus = 11,
Pachycondyla_striata = 10,
Apterostigma_serratum = 9,
Brachymyrmex_delabiei = 8,
Brachymyrmex_feitosai = 7,
Camponotus_fallatus = 6,
Camponotus_hermanni = 5,
Camponotus_xanthogaster = 4,
Pheidole_aberrans = 3,
Pheidole_fimbriata = 3,
Pheidole_obscurithorax = 2,
Pheidole_subarmata = 2,
Strumigenys_fridericimuelleri = 2,
Heteroponera_inermis = 2,
Oxyepoecus_browni = 2,
Sphinctomyrmex_stali = 1,
Strumigenys_sanctipauli = 1,
Brachymyrmex_micromegas = 1,
Camponotus_tripartitus = 1,
Diaphoromyrma_sofiae = 1
)
comunidade <- data.frame(t(species_abundance))
names(comunidade) <- gsub("_", " ", names(species_abundance))
total_abundancia <- sum(comunidade)
# -----------------------------------------------------
# 2. Tema personalizado com fontes grandes
# -----------------------------------------------------
tema_grande <- theme_classic() +
theme(
axis.text.x = element_text(size = 18, angle = 45, hjust = 1),
axis.text.y = element_text(size = 18),
axis.title = element_text(size = 20, face = "bold"),
plot.title = element_text(size = 22, face = "bold", hjust = 0.5),
legend.title = element_text(size = 18, face = "bold"),
legend.text = element_text(size = 16),
panel.grid = element_blank(),
axis.line = element_line(color = "black", linewidth = 0.8),
axis.ticks = element_line(color = "black", linewidth = 0.8),
axis.ticks.length = unit(0.2, "cm")
)
# Tema para gráficos com nomes de espécies em itálico
tema_especies <- tema_grande +
theme(axis.text.x = element_text(size = 18, angle = 45, hjust = 1, face = "italic"))
# -----------------------------------------------------
# 3. Função auxiliar para salvar PDF multipágina
# -----------------------------------------------------
salvar_pdf <- function(plots, arquivo, largura = 12, altura = 8) {
pdf(arquivo, width = largura, height = altura)
for (p in plots) {
if (!is.null(p) && inherits(p, "ggplot")) print(p)
}
dev.off()
message("Salvo: ", arquivo)
}
# -----------------------------------------------------
# 4. GUILDAS
# -----------------------------------------------------
message("Gerando figuras de guildas...")
guildas <- assign_guild_ants(comunidade, verbose = FALSE, plot = FALSE, validate = FALSE)
# Recriar os 4 gráficos com tema grande
plots_guildas <- list()
guild_cols <- c("antclassify_guild", "silva_guild", "delabie_guild", "silvestre_guild")
titulos <- c("Functional Guilds - AntClassify",
"Functional Guilds - Silva et al. (2015)",
"Functional Guilds - Delabie et al. (2000)",
"Functional Guilds - Silvestre & Brandão (2003)")
for (i in seq_along(guild_cols)) {
dados <- guildas$table %>%
group_by(guild = !!sym(guild_cols[i])) %>%
summarise(abundancia = sum(abundance), .groups = "drop") %>%
mutate(prop = abundancia / sum(abundancia))
p <- ggplot(dados, aes(x = reorder(guild, prop), y = prop, fill = guild)) +
geom_col(color = "black", width = 0.7, linewidth = 0.5) +
coord_flip() +
scale_y_continuous(labels = percent_format(accuracy = 1)) +
scale_x_discrete(labels = function(x) stringr::str_wrap(x, width = 50)) +
labs(title = titulos[i], x = "Functional Guild", y = "Proportion") +
tema_grande +
theme(legend.position = "none")
plots_guildas[[i]] <- p
}
salvar_pdf(plots_guildas, "antclassify-guilds-plot.pdf", largura = 14, altura = 9)
# -----------------------------------------------------
# 5. EXÓTICAS
# -----------------------------------------------------
message("Gerando figuras de exóticas...")
# Obter dados (sem plotar)
exo <- check_exotic_ants(comunidade, verbose = FALSE, plot = FALSE, validate = FALSE)
exo_tab <- exo$table
# Gráfico de status
total_exo <- sum(exo_tab$abundance)
dados_status <- data.frame(
status = c("Exotic", "Native/Not Listed"),
abundancia = c(total_exo, total_abundancia - total_exo)
) %>%
mutate(prop = abundancia / sum(abundancia))
p_exo_status <- ggplot(dados_status, aes(x = reorder(status, prop), y = prop, fill = status)) +
geom_col(color = "black", width = 0.7, linewidth = 0.5) +
scale_y_continuous(labels = percent_format(accuracy = 1)) +
scale_fill_manual(values = c("Exotic" = "#d95f02", "Native/Not Listed" = "#1b9e77")) +
labs(title = "Proportion of Exotic vs. Native Species", x = "Status", y = "Proportion") +
tema_grande +
theme(legend.position = "none")
# Gráfico de espécies (se houver)
if (nrow(exo_tab) > 0) {
exo_tab <- exo_tab %>%
mutate(prop_community = abundance / total_abundancia)
p_exo_species <- ggplot(exo_tab, aes(x = reorder(species, -prop_community), y = prop_community)) +
geom_col(fill = "#d95f02", color = "black", width = 0.7, linewidth = 0.5) +
scale_y_continuous(labels = percent_format(accuracy = 0.1)) +
labs(title = "Exotic Species Detected", x = NULL, y = "Proportion of Total Community") +
tema_especies +
theme(legend.position = "none")
} else {
p_exo_species <- ggplot() + annotate("text", x=1, y=1, label="No exotic species") + theme_void()
}
salvar_pdf(list(p_exo_status, p_exo_species), "antclassify-exotics-plot.pdf", largura = 12, altura = 8)
# -----------------------------------------------------
# 6. ENDÊMICAS
# -----------------------------------------------------
message("Gerando figuras de endêmicas...")
end <- check_endemic_atlantic_ants(comunidade, verbose = FALSE, plot = FALSE, validate = FALSE)
end_tab <- end$table
total_end <- sum(end_tab$abundance)
dados_end_status <- data.frame(
status = c("Endemic (AF)", "Other/Not Listed"),
abundancia = c(total_end, total_abundancia - total_end)
) %>%
mutate(prop = abundancia / sum(abundancia))
p_end_status <- ggplot(dados_end_status, aes(x = reorder(status, prop), y = prop, fill = status)) +
geom_col(color = "black", width = 0.7, linewidth = 0.5) +
scale_y_continuous(labels = percent_format(accuracy = 1)) +
scale_fill_manual(values = c("Endemic (AF)" = "#2c7bb6", "Other/Not Listed" = "#abd9e9")) +
labs(title = "Proportion of Atlantic Forest Endemic Species", x = "Status", y = "Proportion") +
tema_grande +
theme(legend.position = "none")
if (nrow(end_tab) > 0) {
end_tab <- end_tab %>% mutate(prop_community = abundance / total_abundancia)
p_end_species <- ggplot(end_tab, aes(x = reorder(species, -prop_community), y = prop_community)) +
geom_col(fill = "#2c7bb6", color = "black", width = 0.7, linewidth = 0.5) +
scale_y_continuous(labels = percent_format(accuracy = 0.1)) +
labs(title = "Endemic Species of the Atlantic Forest", x = NULL, y = "Proportion of Total Community") +
tema_especies +
theme(legend.position = "none")
} else {
p_end_species <- ggplot() + annotate("text", x=1, y=1, label="No endemic species") + theme_void()
}
salvar_pdf(list(p_end_status, p_end_species), "antclassify-endemics-plot.pdf", largura = 12, altura = 8)
# -----------------------------------------------------
# 7. RARIDADE
# -----------------------------------------------------
message("Gerando figuras de raridade...")
rar <- check_rarity_atlantic_ants(comunidade, verbose = FALSE, plot = FALSE, validate = FALSE)
rar_tab <- rar$table   # já contém rarity_form
# Incluir espécies comuns no gráfico de status
dados_rar_status <- rar_tab %>%
group_by(rarity_form) %>%
summarise(abundancia = sum(abundance), .groups = "drop") %>%
mutate(prop = abundancia / sum(abundancia))
# Adicionar "Common" se não estiver presente
if (!"Common" %in% dados_rar_status$rarity_form) {
total_comum <- total_abundancia - sum(rar_tab$abundance)
dados_rar_status <- rbind(dados_rar_status,
data.frame(rarity_form = "Common", abundancia = total_comum, prop = total_comum / total_abundancia))
}
p_rar_status <- ggplot(dados_rar_status, aes(x = reorder(rarity_form, prop), y = prop, fill = rarity_form)) +
geom_col(color = "black", width = 0.7, linewidth = 0.5) +
scale_y_continuous(labels = percent_format(accuracy = 1)) +
labs(title = "Ant Rarity Forms Distribution", x = "Rarity Classification", y = "Proportion") +
tema_grande +
theme(legend.position = "bottom", legend.title = element_blank())
if (nrow(rar_tab) > 0) {
rar_tab <- rar_tab %>% mutate(prop_community = abundance / total_abundancia)
p_rar_species <- ggplot(rar_tab, aes(x = reorder(species, -prop_community), y = prop_community, fill = rarity_form)) +
geom_col(color = "black", width = 0.7, linewidth = 0.5) +
scale_y_continuous(labels = percent_format(accuracy = 0.1)) +
labs(title = "Rare Species Abundance by Rarity Form", x = NULL, y = "Proportion of Total Community", fill = "Rarity Form") +
tema_especies +
theme(legend.position = "right")
} else {
p_rar_species <- ggplot() + annotate("text", x=1, y=1, label="No rare species") + theme_void()
}
salvar_pdf(list(p_rar_status, p_rar_species), "antclassify-rarity-plot.pdf", largura = 14, altura = 8)
message("Todas as figuras foram geradas com sucesso!")
# ... (código anterior igual) ...
# -----------------------------------------------------
# 4. GUILDAS
# -----------------------------------------------------
message("Gerando figuras de guildas...")
guildas <- assign_guild_ants(comunidade, verbose = FALSE, plot = FALSE, validate = FALSE)
# Recriar os 4 gráficos com tema grande
plots_guildas <- list()
guild_cols <- c("antclassify_guild", "silva_guild", "delabie_guild", "silvestre_guild")
titulos <- c("Functional Guilds - AntClassify",
"Functional Guilds - Silva et al. (2015)",
"Functional Guilds - Delabie et al. (2000)",
"Functional Guilds - Silvestre et al. (2003)")   # <-- CORRIGIDO AQUI
for (i in seq_along(guild_cols)) {
dados <- guildas$table %>%
group_by(guild = !!sym(guild_cols[i])) %>%
summarise(abundancia = sum(abundance), .groups = "drop") %>%
mutate(prop = abundancia / sum(abundancia))
p <- ggplot(dados, aes(x = reorder(guild, prop), y = prop, fill = guild)) +
geom_col(color = "black", width = 0.7, linewidth = 0.5) +
coord_flip() +
scale_y_continuous(labels = percent_format(accuracy = 1)) +
scale_x_discrete(labels = function(x) stringr::str_wrap(x, width = 50)) +
labs(title = titulos[i], x = "Functional Guild", y = "Proportion") +
tema_grande +
