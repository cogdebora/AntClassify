# =====================================================
library(AntClassify)
library(ggplot2)
library(dplyr)
library(scales)
# -----------------------------------------------------
# 1. Dados da comunidade (simulados do artigo)
# -----------------------------------------------------
species_abundance <- c(
Atta_sexdens = 50,
Camponotus_atriceps = 40,
Crematogaster_sp = 35,
Cyphomyrmex_minutus = 30,
Cyphomyrmex_rimosus = 28,
Ectatomma_edentatum = 25,
Heteroponera_mayri = 22,
Holcoponera_striatula = 20,
Monomorium_floricola = 18,
Monomorium_pharaonis = 17,
Pheidole_megacephala = 16,
Strumigenys_emmae = 15,
Strumigenys_rogeri = 14,
Nylanderia_fulva = 13,
Odontomachus_chelifer = 12,
Oxyepoecus_reticulatus = 11,
Pachycondyla_striata = 10,
Apterostigma_serratum = 9,
Brachymyrmex_delabiei = 8,
Brachymyrmex_feitosai = 7,
Camponotus_fallatus = 6,
Camponotus_hermanni = 5,
Camponotus_xanthogaster = 4,
Pheidole_aberrans = 3,
Pheidole_fimbriata = 3,
Pheidole_obscurithorax = 2,
Pheidole_subarmata = 2,
Strumigenys_fridericimuelleri = 2,
Heteroponera_inermis = 2,
Oxyepoecus_browni = 2,
Sphinctomyrmex_stali = 1,
Strumigenys_sanctipauli = 1,
Brachymyrmex_micromegas = 1,
Camponotus_tripartitus = 1,
Diaphoromyrma_sofiae = 1
)
comunidade <- data.frame(t(species_abundance))
names(comunidade) <- gsub("_", " ", names(species_abundance))
# -----------------------------------------------------
# 2. Tema com fontes grandes (o mesmo do artigo)
# -----------------------------------------------------
tema_grande <- theme_classic() +
theme(
axis.text.x = element_text(size = 18),
axis.text.y = element_text(size = 18),
axis.title = element_text(size = 20, face = "bold"),
plot.title = element_text(size = 22, face = "bold", hjust = 0.5),
legend.position = "none",
panel.grid = element_blank(),
axis.line = element_line(color = "black", linewidth = 0.8),
axis.ticks = element_line(color = "black", linewidth = 0.8),
axis.ticks.length = unit(0.2, "cm")
)
# -----------------------------------------------------
# 3. Obter classificação das guildas (sem plotar)
# -----------------------------------------------------
guildas <- assign_guild_ants(comunidade, verbose = FALSE, plot = FALSE, validate = FALSE)
# -----------------------------------------------------
# 4. Função para criar gráfico COM RÓTULOS
# -----------------------------------------------------
criar_grafico_guilda <- function(dados, coluna_guilda, titulo) {
# Agrupar por guilda e calcular proporção
resumo <- dados$table %>%
group_by(guild = !!sym(coluna_guilda)) %>%
summarise(abundancia = sum(abundance), .groups = "drop") %>%
mutate(prop = abundancia / sum(abundancia))
ggplot(resumo, aes(x = reorder(guild, prop), y = prop, fill = guild)) +
geom_col(color = "black", width = 0.7, linewidth = 0.5) +
coord_flip() +
# Espaço extra à direita para os rótulos não serem cortados
scale_y_continuous(
labels = percent_format(accuracy = 1),
expand = expansion(mult = c(0, 0.25))
) +
scale_x_discrete(labels = function(x) stringr::str_wrap(x, width = 50)) +
# Rótulos com o valor percentual
geom_text(
aes(label = percent(prop, accuracy = 0.1)),
hjust = -0.2,          # posiciona à direita da barra
size = 6,
fontface = "bold"
) +
labs(title = titulo, x = "Functional Guild", y = "Proportion") +
tema_grande
}
# -----------------------------------------------------
# 5. Criar e exibir os quatro gráficos
# -----------------------------------------------------
p1 <- criar_grafico_guilda(guildas, "antclassify_guild", "Functional Guilds - AntClassify")
p2 <- criar_grafico_guilda(guildas, "silva_guild", "Functional Guilds - Silva et al. (2015)")
p3 <- criar_grafico_guilda(guildas, "delabie_guild", "Functional Guilds - Delabie et al. (2000)")
p4 <- criar_grafico_guilda(guildas, "silvestre_guild", "Functional Guilds - Silvestre et al. (2003)")
# Exibir um por um (aperte Enter no console para avançar)
print(p1)
print(p2)
print(p3)
print(p4)
# Usando a função com rótulos internos
p1_clean <- criar_grafico_guilda_clean(guildas, "antclassify_guild", "AntClassify - com rótulos clean")
